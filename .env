# ==========================================
# 核心密钥配置
# ==========================================
# 你的 DeepSeek API Key
LLM_API_KEY="sk-32dc4b9ce3214ef4bb83cb0a9a797d19"
LLM_MODEL_ID="qwen-plus"
LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# 是否让大模型客户端继承系统代理。当前若代理异常，建议保持 false。
LLM_USE_ENV_PROXY="false"
# 大模型请求超时秒数
LLM_TIMEOUT_SEC="120"
# 是否让 WebSearchTool 继承/使用代理。建议设为 true。
WEB_SEARCH_USE_ENV_PROXY="true"
# WebSearchTool 专用代理；如果留空，会回退读取当前 shell 中的 http_proxy/https_proxy/all_proxy
WEB_SEARCH_HTTP_PROXY="http://172.17.16.1:7897"
WEB_SEARCH_HTTPS_PROXY="http://172.17.16.1:7897"
WEB_SEARCH_ALL_PROXY="socks5://172.17.16.1:7897"
WEB_SEARCH_NO_PROXY="127.0.0.1,localhost"
# Hugging Face 镜像地址，运行时默认优先走镜像
HF_ENDPOINT="https://hf-mirror.com"
# 是否自动下载缺失的 NLTK 资源。离线环境建议保持 false。
NLTK_AUTO_DOWNLOAD="false"

# ==========================================
# RAG 模型配置
# ==========================================
# 在线法：直接填写 Hugging Face 模型 ID
EMBEDDING_MODEL_PATH="./data/gte-small-zh"
# embedding 编码设备：有 GPU 时建议设为 cuda
EMBEDDING_DEVICE="cuda"
# embedding 批大小：显存够可以适当调大，加快索引构建
EMBEDDING_BATCH_SIZE="128"
# FAISS 增量构建批大小：内存紧张时可以调小，例如 128 / 256
FAISS_BUILD_BATCH_SIZE="32"
# 处理扫描版 PDF 时启用 OCR
OCR_ENABLED="true"
# 是否强制完整重建索引：首次完整重建时设为 true，完成后改回 false
FORCE_REBUILD_INDEX="false"
# 图书馆库存数据库连接串（SQLite 或 MySQL）
LIBRARY_DB_URL=""
# 数据库表与字段映射
LIBRARY_BOOKS_TABLE="books"
LIBRARY_INVENTORY_TABLE="inventory"
LIBRARY_BOOK_ID_COLUMN="id"
LIBRARY_INVENTORY_BOOK_ID_COLUMN="book_id"
LIBRARY_TITLE_COLUMN="title"
LIBRARY_ISBN_COLUMN="isbn"
LIBRARY_AVAILABLE_COUNT_COLUMN="available_count"
LIBRARY_TOTAL_COUNT_COLUMN="total_count"
LIBRARY_SHELF_LOCATION_COLUMN="shelf_location"
LIBRARY_STATUS_COLUMN="status"
# 日志目录：会生成 agentic_rag.log
LOG_DIR="./logs/rag"

# ==========================================
# 路径配置 (建议使用相对路径)
# ==========================================
# 原始数据存放路径
DATA_PATH="./data/rag"
# 缓存目录
TMP_PATH="./temp"
# FAISS 向量索引保存目录
INDEX_DIR="./data/faiss_rag"
